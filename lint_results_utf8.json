cas();\r\n    }, [userData]);\r\n\r\n    const calcDias = (data?: string | null) => {\r\n        if (!data) return 999;\r\n        return Math.ceil((new Date(data).getTime() - Date.now()) / 86400000);\r\n    };\r\n\r\n    const licencaLabels: Record<string, string> = {\r\n        alvara: \"Alvar├í de Funcionamento\",\r\n        vigilancia_sanitaria: \"Vigil├óncia Sanit├íria\",\r\n        corpo_bombeiros: \"Corpo de Bombeiros\",\r\n        meio_ambiente: \"Meio Ambiente\"\r\n    };\r\n\r\n    if (loading) {\r\n        return <div className=\"flex items-center justify-center h-64\"><div className=\"w-8 h-8 border-4 border-primary border-t-transparent rounded-full animate-spin\" /></div>;\r\n    }\r\n\r\n    return (\r\n        <div className=\"space-y-6 animate-fade-in\">\r\n            <div className=\"flex items-center gap-3\">\r\n                <div className=\"w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary shadow-inner\">\r\n                    <ScrollText size={24} />\r\n                </div>\r\n                <div>\r\n                    <h1 className=\"text-2xl font-bold tracking-tight\">Licen├ºas Municipais</h1>\r\n                    <p className=\"text-muted-foreground\">Documenta├º├úo e alvar├ís da sua empresa</p>\r\n                </div>\r\n            </div>\r\n\r\n            {licencas.length === 0 ? (\r\n                <Card className=\"border-dashed border-2 bg-muted/20\">\r\n                    <CardContent className=\"flex flex-col items-center justify-center py-12 text-center\">\r\n                        <ShieldCheck size={48} className=\"text-muted-foreground/30 mb-4\" />\r\n                        <p className=\"text-lg font-medium text-muted-foreground\">Nenhuma licen├ºa cadastrada no momento.</p>\r\n                        <p className=\"text-sm text-muted-foreground max-w-xs\">\r\n                            Sua equipe de contabilidade ir├í cadastrar as licen├ºas assim que estiverem dispon├¡veis.\r\n    