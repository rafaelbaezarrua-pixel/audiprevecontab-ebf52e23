 } = await supabase.from(\"certidoes\").select(\"*\", { count: 'exact', head: true }).eq(\"empresa_id\", userData.empresaId);\r\n            const { count: msgCount } = await supabase.from(\"internal_messages\" as any).select(\"*\", { count: 'exact', head: true }).eq(\"empresa_id\", userData.empresaId).eq(\"lida\", false).eq(\"direcao\", \"escritorio_para_cliente\");\r\n\r\n            setCounts({\r\n                lics: licCount || 0,\r\n                certs: certCount || 0,\r\n                msgs: msgCount || 0\r\n            });\r\n        };\r\n        load();\r\n    }, [userData]);\r\n\r\n    const stats = [\r\n        { label: \"Licen├ºas Ativas\", value: counts.lics.toString(), icon: FileText, color: \"text-amber-500\", bg: \"bg-amber-500/10\" },\r\n        { label: \"Certid├Áes Dispon├¡veis\", value: counts.certs.toString(), icon: CheckCircle, color: \"text-green-500\", bg: \"bg-green-500/10\" },\r\n        { label: \"Mensagens N├úo Lidas\", value: counts.msgs.toString(), icon: MessageSquare, color: \"text-blue-500\", bg: \"bg-blue-500/10\" },\r\n    ];\r\n\r\n    return (\r\n        <div className=\"space-y-8 animate-fade-in\">\r\n            <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4\">\r\n                <div>\r\n                    <h1 className=\"text-3xl font-bold tracking-tight\">Bem-vindo, {userData?.nome}!</h1>\r\n                    <p className=\"text-muted-foreground mt-1 text-lg\">\r\n                        Acompanhe a situa├º├úo da sua empresa em tempo real.\r\n                    </p>\r\n                </div>\r\n                <div className=\"flex items-center gap-3 bg-card p-4 rounded-2xl border border-border shadow-sm\">\r\n                    <div className=\"w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary\">\r\n                        <Building2 size={24} />\r\n                    </div>\r\n                    <div>\r\n                        <p className=\"text-