# --- SUPABASE ---
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# --- FILEBROWSER ---
FILEBROWSER_URL=http://localhost:8081
FILEBROWSER_USER=admin
FILEBROWSER_PASS=your-strong-password-here

# --- VERCEL (INTERNAL) ---
# VERCEL_OIDC_TOKEN=internal-token-do-not-manually-edit

# --- RECAPTCHA ---
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here
